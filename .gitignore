# Credentials — never commit. Use .env.example as the template.
.env
.env.local
.env.*.local
.env.*
!.env.example
!.env.sample

# Private keys + certs
*.pem
*.key
*.crt
*.p12
*.pfx

# Secret directories
.secrets/

# Workspace auth tokens
.auth-token
.auth_token

# Python build artifacts — never commit; regenerated by interpreter / pip.
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
build/
dist/
